# =============================================================================
# SkillSQL-RL :: ROOT environment (shared defaults)
# Copy to `.env`. Each agent under src/skillsql/agents/<name>/.env overrides
# these values for that agent only (override precedence; see config/env_loader.py).
# Never commit real secrets -- use a secret manager in production.
# =============================================================================

SKILLSQL_ENV=dev                       # dev | staging | prod
LOG_LEVEL=DEBUG                         # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                         # true -> JSON logs (prod)
LOG_FILE=logs/app.log
LOG_FILE_WHEN=midnight
LOG_FILE_INTERVAL=1
LOG_FILE_BACKUP_COUNT=7

# JSON array or comma-separated module names. Disabled modules are forced to WARNING.
DISABLE_NOISY_MODULES=["aiohttp","asyncio","google.adk","snowflake.connector","urllib3"]
# Enabled modules are forced to ENABLE_NOISY_MODULES_LOG_LEVEL.
ENABLE_NOISY_MODULES=[]
ENABLE_NOISY_MODULES_LOG_LEVEL=DEBUG

# SQLAlchemy statement logging. Keep parameters hidden unless debugging locally.
SQLALCHEMY_LOG_SQL=false
SQLALCHEMY_LOG_LEVEL=INFO
SQLALCHEMY_HIDE_PARAMETERS=true

# ---- Two DSNs: app catalog vs. ADK sessions/events (kept logically distinct) ----
# App-specific catalog + SkillBank (pgvector). SQLAlchemy sync URL.
APP_CATALOG_DSN=postgresql+psycopg://skillsql:skillsql@localhost:5432/skillsql_catalog
APP_CATALOG_SCHEMA=skillsql_catalog
# ADK sessions/events store. ADK/SQLAlchemy async URL (asyncpg).
ADK_SESSION_DSN=postgresql+asyncpg://skillsql:skillsql@localhost:5432/skillsql_adk
ADK_APP_NAME=skillsql_rl

# ---- Default datasource under test ----
# DATASOURCE_TYPE: snowflake (default) | postgres | starburst | oracle
DATASOURCE_TYPE=snowflake

# ---- Snowflake (default datasource) ----
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=SKILLSQL_RO          # a READ-ONLY role is mandatory
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_AUTHENTICATOR=snowflake   # snowflake | externalbrowser | oauth | ...
# Optional key-pair auth (preferred in prod): path to PEM private key.
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_QUERY_TAG=skillsql_rl

# ---- Starburst Galaxy / Trino ----
# Galaxy account-domain API (metadata + OAuth):
STARBURST_URL=
STARBURST_HOST=
STARBURST_API_URL=
STARBURST_PORT=443

# Trino cluster-domain (query execution):
STARBURST_TRINO_HOST=
STARBURST_TRINO_URL=

# Auth: Basic auth for Trino, OAuth client credentials for Galaxy API.
STARBURST_USER=
STARBURST_PASSWORD=
STARBURST_ROLE=
STARBURST_CLIENT_ID=
STARBURST_CLIENT_SECRET=

# Default catalog/schema for SQL generation context:
STARBURST_CATALOG=
STARBURST_SCHEMA=
# Keep true in prod. Set false only for local/corporate CA troubleshooting.
STARBURST_VERIFY_SSL=true
STARBURST_TIMEOUT_MS=300000

# Query history cluster (may be same as primary Trino cluster):
STARBURST_QUERY_HISTORY_TRINO_URL=
STARBURST_QUERY_HISTORY_TRINO_HOST=
STARBURST_QUERY_HISTORY_USER=
STARBURST_QUERY_HISTORY_PASSWORD=
STARBURST_QUERY_HISTORY_ROLE=

# ---- Execution safety limits (enforced by every connector) ----
SQL_STATEMENT_TIMEOUT_S=60
SQL_ROW_CAP=5000
SQL_READ_ONLY=true

# ---- Models ---------------------------------------------------------------
OLLAMA_API_BASE=http://localhost:11434

# Default chat model for all ADK workflow agents except query generation.
ADK_MODEL_PROVIDER=ollama              # ollama | vertex | openai | azure_openai | anthropic | bedrock | litellm
ADK_MODEL=ollama_chat/llama3.1:8b
DEFAULT_CHAT_MODEL=ollama_chat/llama3.1:8b
# Optional for OpenAI-compatible/LiteLLM providers.
ADK_MODEL_API_BASE=
ADK_MODEL_API_KEY=
ADK_MODEL_API_VERSION=
ADK_MODEL_TIMEOUT_SECONDS=1800
ADK_MODEL_MAX_RETRIES=1
ADK_MODEL_RETRY_BACKOFF_INITIAL_SECONDS=2
ADK_MODEL_RETRY_BACKOFF_MAX_SECONDS=30

# Query generator model. Keep this on the Text2SQL model for local testing.
QUERY_GENERATOR_MODEL_PROVIDER=ollama
QUERY_GENERATOR_MODEL=a-kore/Arctic-Text2SQL-R1-7B:latest
QUERY_GENERATOR_MODEL_API_BASE=
QUERY_GENERATOR_MODEL_API_KEY=
QUERY_GENERATOR_MODEL_API_VERSION=
QUERY_GENERATOR_MODEL_TIMEOUT_SECONDS=1800
QUERY_GENERATOR_MODEL_MAX_RETRIES=1
QUERY_GENERATOR_MODEL_RETRY_BACKOFF_INITIAL_SECONDS=2
QUERY_GENERATOR_MODEL_RETRY_BACKOFF_MAX_SECONDS=30
# Legacy fallback used by older config; prefer QUERY_GENERATOR_MODEL.
OLLAMA_MODEL=a-kore/Arctic-Text2SQL-R1-7B:latest

# Embeddings (pluggable). Default = local Ollama embedding model.
EMBEDDING_PROVIDER=ollama               # ollama | openai | openai_compatible | vertex | litellm
EMBEDDING_MODEL=snowflake-arctic-embed:l
EMBEDDING_DIM=1024                      # MUST match the pgvector column dimension
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# ---- Benchmark ----
SPIDER2_SNOW_JSONL=./data/spider2-snow.jsonl
BENCH_GROUP_SIZE=8                      # G candidates per question
BENCH_ORACLE_TABLES=false               # label runs that use oracle tables separately
